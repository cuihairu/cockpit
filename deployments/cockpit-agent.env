# Cockpit Agent 环境配置
# 复制此文件到 /etc/default/cockpit-agent 或 /etc/sysconfig/cockpit-agent

# Server WebSocket 地址 (必需)
# 使用 ws:// 非加密或 wss:// 加密
SERVER_URL=ws://cockpit.example.com:8080

# 地域 (可选，用于分组管理)
# 示例: jiangsu-huaian, aliyun-cn-hangzhou, aws-us-east-1
REGION=

# 可用区 (可选)
# 示例: datacenter-a, zone-b, home-lab
ZONE=

# Agent ID (可选，默认自动生成)
# 指定后可保持身份稳定，重连后 ID 不变
# AGENT_ID=
